---
import { getCollection } from 'astro:content';
import {
  getProjectCoverClasses,
  getProjectSlug,
  getProjectTone,
  getProjectToneLabel,
} from '../../lib/project-presentation';
import { withBase } from '../../lib/site';

type BucketKey = 'primary' | 'workspace' | 'archived' | 'lab';
type VisibleBucketKey = Exclude<BucketKey, 'archived'>;

const bucketMeta: Record<
  BucketKey,
  { title: string; description: string; accent: string }
> = {
  primary: {
    title: 'Primary Systems',
    description: 'Core product lines and infrastructure that define my active technical narrative.',
    accent: 'from-primary/20 to-primary/5',
  },
  workspace: {
    title: 'Workspaces',
    description: 'Containers for specialized workstreams, product branches, and multi-repo architectures.',
    accent: 'from-secondary/20 to-secondary/5',
  },
  archived: {
    title: 'Legacy Variants',
    description: 'Earlier technical signals that provide context on product evolution and range.',
    accent: 'from-accent/20 to-accent/5',
  },
  lab: {
    title: 'Research Labs',
    description: 'Explorations in AI auditability, interface security, and civic-tech prototypes.',
    accent: 'from-sage/20 to-sage/5',
  },
};

const bucketOrder: BucketKey[] = ['primary', 'workspace', 'archived', 'lab'];
const visibleBucketOrder: VisibleBucketKey[] = ['primary', 'workspace', 'lab'];

const allProjects = (await getCollection('projects'))
  .map((entry) => entry.data)
  .sort((left, right) => {
    const bucketDelta =
      bucketOrder.indexOf(left.bucket) - bucketOrder.indexOf(right.bucket);

    if (bucketDelta !== 0) {
      return bucketDelta;
    }

    if (left.featured !== right.featured) {
      return left.featured ? -1 : 1;
    }

    return left.title.localeCompare(right.title);
  });

const projects = allProjects.filter((project) => project.bucket !== 'archived');
const totalProjects = projects.length;
const activeProjects = projects.filter((project) => project.lifecycle === 'active').length;
const featuredProjects = projects.filter((project) => project.featured).length;

const groupedProjects = visibleBucketOrder.map((bucket) => ({
  bucket,
  meta: bucketMeta[bucket],
  items: projects.filter((project) => project.bucket === bucket),
}));

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Dreamcoder08 Project Catalog',
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: totalProjects,
  itemListElement: projects.map((project, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: project.title,
    description: project.summary,
    category: project.domain,
  })),
};
---

<section
  id="projects"
  class="py-24 sm:py-32 bg-transparent relative overflow-hidden"
  aria-labelledby="projects-heading"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <header class="max-w-4xl mx-auto text-center mb-20">
      <p class="inline-flex items-center rounded-full border border-primary/40 bg-primary/15 px-6 py-2 text-[10px] font-black uppercase tracking-[0.25em] text-primary shadow-soft">
        Project Signals
      </p>
      <h2 id="projects-heading" class="mt-6 text-4xl md:text-5xl lg:text-7xl font-display font-black tracking-tighter text-foreground">
        <span class="gradient-text-primary text-shadow-glow">Public Systems</span>
        <span>, curated for auditability.</span>
      </h2>
      <p class="mt-6 text-lg md:text-xl text-foreground/80 leading-relaxed max-w-2xl mx-auto font-medium">
        Selected signals from my technical work. Organized by primary systems, 
        active workspaces, and research tracks.
      </p>
    </header>

    <div class="grid gap-6 md:grid-cols-3 mb-24">
      <div class="glass-card p-8 border-border/30">
        <p class="font-code text-[10px] uppercase tracking-[0.22em] text-muted-foreground font-bold">Total Signals</p>
        <p class="mt-2 text-5xl font-display font-black text-foreground tracking-tight">{totalProjects}</p>
        <p class="mt-4 text-sm text-foreground/70 leading-relaxed font-medium">Visible technical signals across active lines and research labs.</p>
      </div>
      <div class="glass-card p-8 border-primary/20">
        <p class="font-code text-[10px] uppercase tracking-[0.22em] text-primary font-bold">Active Systems</p>
        <p class="mt-2 text-5xl font-display font-black text-primary tracking-tight">{activeProjects}</p>
        <p class="mt-4 text-sm text-foreground/70 leading-relaxed font-medium">Infrastructure and products currently in active, high-trust development.</p>
      </div>
      <div class="glass-card p-8 border-accent/20">
        <p class="font-code text-[10px] uppercase tracking-[0.22em] text-accent font-bold">Featured Tracks</p>
        <p class="mt-2 text-5xl font-display font-black text-accent tracking-tight">{featuredProjects}</p>
        <p class="mt-4 text-sm text-foreground/70 leading-relaxed font-medium">Anchor projects that define the core technical and audit narrative.</p>
      </div>
    </div>

    <div class="space-y-32">
      {
        groupedProjects.map(({ bucket, meta, items }) => (
          <section aria-labelledby={`${bucket}-heading`}>
            <div class={`rounded-[40px] border border-border/40 bg-gradient-to-r ${meta.accent} p-10 sm:p-12 shadow-elevated`}>
              <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
                <div>
                  <h3 id={`${bucket}-heading`} class="text-4xl sm:text-5xl font-display font-black text-foreground tracking-tighter">
                    {meta.title}
                  </h3>
                  <p class="mt-4 max-w-3xl text-lg sm:text-xl text-foreground/90 leading-relaxed font-medium">
                    {meta.description}
                  </p>
                </div>
                <p class="font-code text-[11px] uppercase tracking-[0.25em] text-foreground/60 bg-white/10 px-6 py-3 rounded-full border border-white/10 font-bold">
                  {items.length} units
                </p>
              </div>
            </div>

            <div class="mt-12 grid gap-10 md:grid-cols-2 xl:grid-cols-3">
              {
                items.map((project) => {
                  const tone = getProjectTone(project.domain, project.bucket);
                  const coverTone = getProjectCoverClasses(tone);
                  const toneLabel = getProjectToneLabel(tone);

                  return (
                    <a
                      href={withBase(`/projects/${getProjectSlug(project.title)}/`)}
                      class="group block rounded-[32px] border border-border/30 bg-card/60 shadow-soft backdrop-blur-2xl transition-all duration-500 hover:-translate-y-3 hover:border-primary/50 hover:shadow-elevated overflow-hidden"
                    >
                      <div class={`relative overflow-hidden border-b border-border/30 bg-gradient-to-br ${coverTone} p-8 ring-1 ring-white/5 transition-all duration-500 group-hover:ring-primary/40`}>
                        <div class="absolute inset-0 bg-grid-pattern opacity-[0.12]" aria-hidden="true"></div>
                        <div class="relative z-10 min-h-[180px] flex flex-col justify-between">
                          <div>
                            <p class="font-code text-[10px] uppercase tracking-[0.22em] text-foreground/70 font-black">
                              {toneLabel}
                            </p>
                            <div class="mt-8">
                              <p class="text-3xl font-display font-black leading-[1.1] text-white tracking-tighter group-hover:text-primary transition-colors">
                                {project.title}
                              </p>
                              <p class="mt-3 text-sm text-foreground/90 font-bold uppercase tracking-widest">
                                {project.domain}
                              </p>
                            </div>
                          </div>
                          <div class="mt-10 flex items-center justify-between text-[10px] font-black uppercase tracking-[0.25em] text-foreground/50">
                            <span class="bg-black/40 px-4 py-1.5 rounded-full border border-white/10">{project.lifecycle}</span>
                            <span class="text-primary group-hover:text-white transition-colors">inspect system</span>
                          </div>
                        </div>
                      </div>

                      <article class="p-8">
                        <div class="flex flex-wrap items-center gap-3">
                          <span class="rounded-full bg-primary/20 border border-primary/30 px-4 py-1.5 text-[10px] font-black uppercase tracking-[0.2em] text-primary">
                            {project.domain}
                          </span>
                          <span class="rounded-full bg-muted/70 border border-border/30 px-4 py-1.5 text-[10px] font-black uppercase tracking-[0.2em] text-foreground/80">
                            v. {project.updatedYear}
                          </span>
                        </div>

                        <p class="mt-6 text-base leading-[1.8] text-foreground/80 font-medium line-clamp-3">
                          {project.summary}
                        </p>

                        <div class="mt-8 flex flex-wrap gap-2.5">
                          {project.stack.slice(0, 4).map((tag) => (
                            <span class="rounded-full border border-border/30 bg-white/10 px-4 py-1.5 text-[11px] font-bold text-foreground/90">
                              {tag}
                            </span>
                          ))}
                        </div>

                        <div class="mt-8 border-t border-border/20 pt-8">
                          <div class="flex items-center justify-between gap-6">
                            <div class="overflow-hidden">
                              <p class="text-[10px] uppercase tracking-[0.25em] text-muted-foreground font-black">
                                Traceability
                              </p>
                              <p class="mt-2 font-code text-[11px] text-foreground/80 font-bold truncate">
                                {project.path}
                              </p>
                            </div>
                            <div class="shrink-0 rounded-full border border-primary/40 bg-primary/10 px-5 py-2.5 text-[10px] font-black uppercase tracking-[0.2em] text-primary transition-all duration-500 group-hover:bg-primary group-hover:text-background group-hover:border-primary group-hover:shadow-glow">
                              Details
                            </div>
                          </div>
                        </div>
                      </article>
                    </a>
                  );
                })
              }
            </div>
          </section>
        ))
      }
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(itemList)}></script>
</section>
