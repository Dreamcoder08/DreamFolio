---
import { ShieldCheck, BrainCircuit, Cpu, ArrowRight } from 'lucide-react'

const principles = [
  {
    title: "Deterministic Traceability",
    desc: "Every state transition must be auditable. We don't trust logs; we trust immutable evidence trails.",
    metric: "100% Audit Coverage",
    accent: "text-primary"
  },
  {
    title: "Constraint-First Architecture",
    desc: "Systems are defined by what they CANNOT do. Limits are the primary defense against operational entropy.",
    metric: "Strict Invariants",
    accent: "text-sage"
  },
  {
    title: "Resilience over Uptime",
    desc: "Uptime is vanity. Resilience—the ability to degrade gracefully and recover autonomously—is sanity.",
    metric: "Self-Healing Cycles",
    accent: "text-lavender"
  }
];
---

<section id="trinity" class="relative overflow-hidden bg-background-deep py-32 sm:py-40">
  <div class="layout-grid">
    
    <div class="col-span-4 md:col-span-8 lg:col-span-12 mb-20 text-center lg:text-left">
      <p class="font-mono text-[10px] font-black text-primary uppercase tracking-[0.5em] mb-8">
        Section 02 // Architectural Invariants
      </p>
      <h2 class="text-[var(--text-fluid-display)] font-display font-black text-foreground tracking-tighter leading-[0.95] italic max-w-5xl">
        "Software is a <span class="text-muted-text/20 not-italic">liability</span> unless it can provide <span class="text-primary underline underline-offset-[12px] decoration-white/10">deterministic evidence</span> of its intent."
      </h2>
    </div>

    <div class="col-span-4 md:col-span-8 lg:col-span-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      {principles.map((p, i) => (
        <div class="group">
          <div class="glass-clay p-8 md:p-12 h-full flex flex-col justify-between border-white/5 transition-all duration-500 hover:-translate-y-2 hover:border-primary/20">
            <div class="space-y-6">
              <span class="font-mono text-[10px] text-muted-text/30 font-black">SYSTEM_PRINCIPLE_0{i + 1}</span>
              <h3 class="text-3xl md:text-4xl font-display font-black text-foreground tracking-tighter leading-tight italic">
                {p.title}
              </h3>
              <p class="text-base text-muted-text leading-relaxed font-medium">
                {p.desc}
              </p>
            </div>
            
            <div class="pt-8 mt-8 border-t border-white/5 flex justify-between items-center">
              <span class:list={["font-mono text-[10px] font-black uppercase tracking-widest", p.accent]}>
                {p.metric}
              </span>
              <ArrowRight class="w-4 h-4 text-muted-text/20 group-hover:text-primary transition-colors" />
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
