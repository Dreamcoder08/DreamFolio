---
const labs = [
  {
    title: 'The Nytherx Visual System',
    description: 'A visual architecture for high-density technical interfaces. Graphite, cocoa, and lucuma copper.',
    mark: 'NY',
    color: 'text-primary',
  },
  {
    title: 'Cocoa Terminal Environment',
    description: 'A workstation stack designed for visual clarity and technical focus. Built with GLSL and Lua.',
    mark: 'CT',
    color: 'text-lucuma',
  },
  {
    title: 'Arkelythex Fiscal Interface',
    description: 'Command center for fiscal evidence, governed agents, and approval-gated execution.',
    mark: 'AX',
    color: 'text-cyan',
  },
  {
    title: 'Design Canon',
    description: 'Cocoa terminal warmth. Audit-first clarity. No decorative complexity. Every element must justify its existence.',
    mark: 'DC',
    color: 'text-sage',
  },
];

const materials = [
  { label: 'Background', value: '#19120C', className: 'bg-[#19120C]' },
  { label: 'Surface', value: '#211810', className: 'bg-surface' },
  { label: 'Lucuma', value: '#FBB974', className: 'bg-primary' },
  { label: 'Evidence Cyan', value: '#9EC3C4', className: 'bg-cyan' },
  { label: 'Sage Status', value: '#9EC49F', className: 'bg-sage' },
];

const canonRules = [
  'Evidence before decoration',
  'Panels behave like inspection tools',
  'Warm terminal, never generic neon',
  'Every element must justify its existence',
];
---

<section id="lab" class="py-32 bg-background-soft/30">
  <div class="layout-grid mb-20">
    <div class="col-span-12 space-y-4">
      <p class="terminal-text text-primary">Section 06 // Visual Systems Laboratory</p>
      <h2 class="text-5xl md:text-7xl font-display font-black text-foreground italic tracking-tighter leading-none">
        Visual Systems Laboratory.
      </h2>
      <p class="max-w-2xl text-lg text-muted-text font-medium leading-relaxed">
        Thinking in systems extends to aesthetics. I design technical interfaces where every element justifies its existence through clarity and architectural intent.
      </p>
    </div>
  </div>

  <div class="layout-grid gap-8">
    {labs.map((lab) => (
      <article class="col-span-4 glass-panel p-8 space-y-6 group transition-all duration-300 hover:-translate-y-1 hover:border-primary/30">
        <div class={`w-12 h-12 rounded-2xl bg-background-deep border border-border flex items-center justify-center ${lab.color}`}>
          <span class="font-mono text-[11px] font-black tracking-[0.2em]" aria-hidden="true">{lab.mark}</span>
        </div>
        <div class="space-y-3">
          <h3 class="text-xl font-display font-black text-foreground uppercase tracking-tight italic">
            {lab.title}
          </h3>
          <p class="text-muted-text font-medium leading-relaxed">
            {lab.description}
          </p>
        </div>
        <div class="flex items-center gap-2 terminal-text text-muted-text transition-colors group-hover:text-primary">
          <span class="h-1.5 w-1.5 rounded-full bg-current" aria-hidden="true"></span>
          <span>Visual Brief</span>
        </div>
      </article>
    ))}
  </div>

  <div class="layout-grid mt-10 gap-8">
    <div class="col-span-4 md:col-span-8 lg:col-span-7 glass-panel p-8 md:p-10">
      <div class="flex items-center justify-between gap-4 mb-8">
        <div>
          <p class="terminal-text text-primary">Material Strip</p>
          <h3 class="mt-2 text-3xl font-display font-black italic tracking-tighter text-foreground">
            Cocoa / Lucuma Interface Tokens
          </h3>
        </div>
        <div class="hidden md:flex h-12 w-12 items-center justify-center rounded-2xl border border-primary/30 text-primary" aria-hidden="true">
          <span class="font-mono text-[10px] font-black">UI</span>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        {materials.map((item) => (
          <div class="rounded-2xl border border-border bg-background-deep/40 p-4">
            <div class={`h-20 rounded-xl border border-white/10 ${item.className}`}></div>
            <p class="mt-4 terminal-text text-[8px] text-muted-text">{item.label}</p>
            <p class="mt-1 font-mono text-[10px] font-black text-foreground">{item.value}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="col-span-4 md:col-span-8 lg:col-span-5 glass-panel p-8 md:p-10">
      <p class="terminal-text text-sage mb-6">Design Canon</p>
      <div class="space-y-4">
        {canonRules.map((rule, index) => (
          <div class="flex items-start gap-4 rounded-2xl border border-white/5 bg-white/[0.025] p-4">
            <span class="font-mono text-[10px] font-black text-primary">
              0{index + 1}
            </span>
            <p class="text-sm md:text-base text-muted-text font-medium leading-relaxed">
              {rule}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
