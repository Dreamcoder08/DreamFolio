---
const protocol = [
  {
    id: '01',
    title: 'Clear first fold',
    description:
      'The visitor must understand the domain, value, proof, and next action without decoding the aesthetic.',
    signal: 'Positioning clarity',
  },
  {
    id: '02',
    title: 'Purposeful interaction',
    description:
      'Motion earns its place only when it reveals context, reduces uncertainty, or improves navigation.',
    signal: 'No ornamental friction',
  },
  {
    id: '03',
    title: 'Proof before claims',
    description:
      'Arkelythex leads the narrative because it connects domain pressure, architecture, and public evidence.',
    signal: 'Arkelythex as anchor',
  },
  {
    id: '04',
    title: 'Performance as design',
    description:
      'Static-first delivery, progressive islands, and readable hierarchy are product quality, not polish.',
    signal: 'Static Astro core',
  },
];
---

<section aria-labelledby="craft-protocol-heading" class="relative overflow-hidden bg-background py-24 md:py-32">
  <div class="layout-grid gap-y-10">
    <div class="col-span-4 md:col-span-8 lg:col-span-5 space-y-5">
      <p class="terminal-text text-primary">Section 02 // Craft Protocol</p>
      <h2 id="craft-protocol-heading" class="text-4xl md:text-6xl font-display font-black italic tracking-tighter text-foreground leading-[0.95]">
        Elite means clear, fast, and provable.
      </h2>
      <p class="text-lg text-muted-text font-medium leading-relaxed max-w-xl">
        The visual system is allowed to be distinctive, but every decision must increase trust, orientation, or proof.
      </p>
    </div>

    <div class="col-span-4 md:col-span-8 lg:col-span-7 grid gap-4 md:grid-cols-2">
      {protocol.map((item) => (
        <article class="group rounded-[2rem] border border-border bg-surface/55 p-6 md:p-7 shadow-clay transition-all duration-500 hover:-translate-y-1 hover:border-primary/30">
          <div class="flex items-start justify-between gap-6">
            <span class="font-mono text-[10px] font-black text-primary/70">{item.id}</span>
            <span class="rounded-full border border-white/10 bg-white/[0.045] px-3 py-1 font-mono text-[9px] font-black uppercase tracking-[0.16em] text-muted-text">
              {item.signal}
            </span>
          </div>
          <h3 class="mt-8 text-2xl font-display font-black italic tracking-tight text-foreground group-hover:text-primary transition-colors">
            {item.title}
          </h3>
          <p class="mt-4 text-sm md:text-base text-muted-text leading-relaxed font-medium">
            {item.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
