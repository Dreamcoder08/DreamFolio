---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Navbar } from '../components/ui/Navbar';
---

<BaseLayout title="404 — Not Found" description="This page doesn't exist.">
  <Navbar client:load />
  <main class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center">
      <p class="text-[var(--color-accent)] font-mono text-8xl font-bold mb-4">404</p>
      <h1 class="text-2xl font-bold mb-4">Page not found</h1>
      <p class="text-[var(--color-text-secondary)] mb-8">This route doesn't exist in this architecture.</p>
      <a href="/DreamFolio/" class="btn-primary inline-flex">Back to home</a>
    </div>
  </main>
</BaseLayout>
