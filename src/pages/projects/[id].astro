---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Navbar } from '../../components/ui/Navbar';
import {
  getProjectCoverClasses,
  getProjectSlug,
  getProjectTone,
  getProjectToneLabel,
} from '../../lib/project-presentation';
import { getProjectCaseStudy } from '../../lib/project-case-studies';
import { withBase } from '../../lib/site';
import { ArrowLeft, ArrowUpRight, ShieldCheck, Target, Activity, Zap } from 'lucide-react';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((entry) => ({
    params: { id: getProjectSlug(entry.data.title) },
    props: { project: entry.data },
  }));
}

const { project } = Astro.props;

const tone = getProjectTone(project.domain, project.bucket);
const coverTone = getProjectCoverClasses(tone);
const toneLabel = getProjectToneLabel(tone);
const outboundUrl = project.liveUrl ?? project.githubUrl;
const caseStudy = getProjectCaseStudy(project.id);
---

<BaseLayout
  title={`${project.title} | Technical Audit Record`}
  description={project.summary}
>
  <Navbar client:load />

  <main class="min-h-screen bg-background pb-32">
    {/* Header Audit Hero */}
    <section class="relative overflow-hidden pt-32 pb-20 md:pt-48 md:pb-32 border-b border-white/5">
      <div class={`absolute inset-0 bg-gradient-to-br ${coverTone} opacity-[0.15]`} aria-hidden="true"></div>
      <div class="absolute inset-0 bg-grid-pattern opacity-[0.08]" aria-hidden="true"></div>

      <div class="layout-grid relative z-10">
        <div class="col-span-4 md:col-span-8 lg:col-span-12">
          <a
            href={withBase('/#projects')}
            class="group inline-flex items-center gap-2 mb-12 text-[10px] font-mono font-black uppercase tracking-[0.3em] text-muted-text hover:text-primary transition-colors"
          >
            <ArrowLeft size={14} className="group-hover:-translate-x-1 transition-transform" />
            Return to Systems Archive
          </a>

          <div class="space-y-6">
            <div class="flex items-center gap-3">
              <div class="w-1.5 h-1.5 rounded-full bg-primary shadow-glow" />
              <span class="font-mono text-[10px] font-black text-primary uppercase tracking-[0.4em]">
                {toneLabel} // ID: {project.id.toUpperCase()}
              </span>
            </div>
            
            <h1 class="text-[var(--text-fluid-display)] font-display font-black text-foreground tracking-tighter leading-[0.85] italic max-w-5xl">
              {project.title}
            </h1>
            
            <p class="max-w-3xl text-[var(--text-fluid-body)] text-muted-text font-medium leading-relaxed">
              {project.summary}
            </p>

            <div class="pt-8 flex flex-wrap gap-3">
              <span class="px-5 py-2 bg-white/5 border border-white/10 rounded-full font-mono text-[10px] text-foreground/80 font-bold uppercase tracking-widest">
                Domain: {project.domain}
              </span>
              <span class="px-5 py-2 bg-white/5 border border-white/10 rounded-full font-mono text-[10px] text-sage font-bold uppercase tracking-widest">
                Status: {project.lifecycle}
              </span>
              <span class="px-5 py-2 bg-white/5 border border-white/10 rounded-full font-mono text-[10px] text-accent font-bold uppercase tracking-widest">
                Last Audit: {project.updatedYear}
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Content Architecture */}
    <section class="py-24">
      <div class="layout-grid items-start gap-y-16">
        
        {/* Main Narrative */}
        <div class="col-span-4 md:col-span-8 lg:col-span-7 space-y-12">
          <div class="glass-clay p-10 md:p-16 border-white/5">
            <span class="font-mono text-[10px] font-black text-muted-text/30 uppercase tracking-[0.4em] mb-10 block">Narrative Analysis</span>
            
            {caseStudy ? (
              <div class="space-y-16">
                <div class="space-y-4">
                  <div class="flex items-center gap-2 text-foreground/40">
                    <Target size={14} strokeWidth={2.5} />
                    <h4 className="font-mono text-[10px] font-black uppercase tracking-widest">The Core Challenge</h4>
                  </div>
                  <p class="text-lg md:text-xl text-foreground/90 leading-relaxed font-medium">
                    {caseStudy.challenge}
                  </p>
                </div>

                <div class="space-y-4">
                  <div class="flex items-center gap-2 text-foreground/40">
                    <Activity size={14} strokeWidth={2.5} />
                    <h4 className="font-mono text-[10px] font-black uppercase tracking-widest">Architectural Approach</h4>
                  </div>
                  <p class="text-lg md:text-xl text-foreground/90 leading-relaxed font-medium">
                    {caseStudy.approach}
                  </p>
                </div>

                <div class="space-y-4">
                  <div class="flex items-center gap-2 text-sage">
                    <ShieldCheck size={14} strokeWidth={2.5} />
                    <h4 className="font-mono text-[10px] font-black uppercase tracking-widest">System Outcome</h4>
                  </div>
                  <p class="text-xl md:text-2xl text-foreground font-black tracking-tight leading-snug italic">
                    {caseStudy.outcome}
                  </p>
                </div>

                <div class="pt-10 border-t border-white/5">
                   <h4 className="font-mono text-[10px] font-black text-muted-text/30 uppercase tracking-widest mb-8">Technical Milestones</h4>
                   <div class="space-y-4">
                      {caseStudy.evidence.map((item) => (
                        <div class="group flex items-start gap-4 p-5 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-primary/20 transition-all">
                          <Zap size={14} className="mt-1 text-primary animate-pulse" />
                          <p class="text-base text-muted-text font-medium leading-relaxed">{item}</p>
                        </div>
                      ))}
                   </div>
                </div>
              </div>
            ) : (
              <p class="text-lg text-muted-text leading-relaxed font-medium italic">
                Detailed audit logs for this system are currently being processed. This unit represents a verified signal within the technical catalog.
              </p>
            )}
          </div>
        </div>

        {/* Sidebar Metadata */}
        <aside class="col-span-4 md:col-span-8 lg:col-span-5 space-y-8 lg:pl-10">
          
          {/* Cover Visualization */}
          <div class="glass-clay overflow-hidden border-white/5 shadow-elevated mb-12">
            {project.coverImage ? (
               <img
                  src={withBase(project.coverImage)}
                  alt={project.title}
                  class="w-full h-auto grayscale hover:grayscale-0 transition-all duration-700"
               />
            ) : (
              <div class={`aspect-video bg-gradient-to-br ${coverTone} opacity-40 flex items-center justify-center p-12`}>
                <span class="font-display font-black text-4xl italic text-foreground/20">{project.title}</span>
              </div>
            )}
          </div>

          <div class="glass-clay p-8 border-white/5 space-y-8">
            <span class="font-mono text-[10px] font-black text-muted-text/30 uppercase tracking-[0.4em] block">System Metadata</span>
            
            <dl class="space-y-6">
              <div>
                <dt class="text-[9px] font-mono font-black uppercase tracking-[0.2em] text-muted-text/40 mb-2">Catalog Integrity Path</dt>
                <dd class="font-mono text-xs text-foreground font-bold break-all bg-background-deep/50 p-3 rounded-lg border border-white/5">{project.path}</dd>
              </div>
              <div>
                <dt class="text-[9px] font-mono font-black uppercase tracking-[0.2em] text-muted-text/40 mb-1">Architecture Stack</dt>
                <dd class="flex flex-wrap gap-2 pt-2">
                  {project.stack.map(s => (
                    <span class="px-3 py-1 bg-primary/10 border border-primary/20 rounded-full font-mono text-[9px] text-primary font-black uppercase tracking-widest">{s}</span>
                  ))}
                </dd>
              </div>
              {caseStudy && (
                <div>
                  <dt class="text-[9px] font-mono font-black uppercase tracking-[0.2em] text-muted-text/40 mb-4">Performance Metrics</dt>
                  <dd class="space-y-3">
                    {caseStudy.metrics.map(m => (
                      <div class="flex justify-between items-center p-3 rounded-xl bg-white/[0.02] border border-white/5">
                        <span class="text-[10px] font-mono text-muted-text uppercase">{m.label}</span>
                        <span class="text-xs font-mono font-black text-foreground uppercase tracking-widest">{m.value}</span>
                      </div>
                    ))}
                  </dd>
                </div>
              )}
            </dl>

            {outboundUrl && (
              <div class="pt-6">
                <a
                  href={outboundUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-full flex items-center justify-center gap-3 py-4 bg-foreground text-background rounded-full font-black uppercase text-[10px] tracking-[0.3em] hover:bg-primary transition-all shadow-clay"
                >
                  {project.liveUrl ? 'Access Live System' : 'Review Source Node'}
                  <ArrowUpRight size={14} />
                </a>
              </div>
            )}
          </div>

          {caseStudy && (
            <div class="flex flex-wrap gap-2 opacity-40 hover:opacity-100 transition-opacity">
               {caseStudy.signals.map(s => (
                 <span class="text-[8px] font-mono font-black text-muted-text uppercase tracking-widest border border-white/10 px-2 py-1 rounded">#{s.replace(/\s+/g, '_')}</span>
               ))}
            </div>
          )}
        </aside>

      </div>
    </section>
  </main>
</BaseLayout>
