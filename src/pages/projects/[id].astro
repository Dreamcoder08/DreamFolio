---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Navbar } from '../../components/ui/Navbar';
import { siteConfig } from '../../lib/site';
import { getProjectSlug } from '../../lib/project-presentation';
import { getProjectCaseStudy } from '../../lib/project-case-studies';
import { withBase } from '../../lib/site';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { id: getProjectSlug(entry.data.title) },
    props: { project: entry.data },
  }));
}

const { project } = Astro.props;

const outboundUrl = project.liveUrl ?? project.githubUrl;
const caseStudy = getProjectCaseStudy(project.id);
const projectImage = project.coverImage ?? '/images/projects/arkelythex-interface.jpg';

const projectJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.title,
  description: project.summary,
  url: new URL(Astro.url.pathname, Astro.site ?? 'https://dreamcoder08.github.io').toString(),
  image: projectImage,
  creator: { '@type': 'Person', name: 'Dreamcoder08', url: 'https://github.com/dreamcoder08' },
  keywords: [project.domain, ...project.stack],
};
---

<BaseLayout title={`${project.title} — Technical Audit`} description={project.summary} image={projectImage} jsonLd={projectJsonLd}>
  <Navbar client:load />

  <main class="pt-24 pb-32">
    <!-- Header -->
    <section class="section-padding px-6">
      <div class="container-wide">
        <a href={withBase('/#projects')} class="inline-flex items-center gap-2 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors mb-8">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
          Back to projects
        </a>

        <div class="flex items-center gap-3 mb-4">
          <span class="tag">{project.domain}</span>
          <span class="text-sm text-[var(--color-text-secondary)]">Updated {project.updatedYear}</span>
        </div>

        <h1 class="text-4xl md:text-6xl font-bold mb-6">{project.title}</h1>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl leading-relaxed">{project.summary}</p>

        <div class="flex flex-wrap gap-2 mt-6">
          {project.stack?.map((tech) => (
            <span class="tag">{tech}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Cover Image -->
    {project.coverImage && (
      <section class="px-6 mb-16">
        <div class="container-wide">
          <div class="aspect-video rounded-2xl overflow-hidden bg-[var(--color-surface-elevated)] border border-[var(--color-border)]">
            <img src={withBase(project.coverImage)} alt={project.coverImageAlt || project.title} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>
      </section>
    )}

    <!-- Content -->
    <section class="px-6">
      <div class="container-wide">
        {caseStudy ? (
          <div class="max-w-3xl space-y-10">
            <div class="card">
              <p class="section-label">Challenge</p>
              <p class="text-lg leading-relaxed">{caseStudy.challenge}</p>
            </div>
            <div class="card">
              <p class="section-label">Approach</p>
              <p class="text-lg leading-relaxed">{caseStudy.approach}</p>
            </div>
            <div class="card">
              <p class="section-label">Outcome</p>
              <p class="text-xl font-bold text-[var(--color-accent)]">{caseStudy.outcome}</p>
            </div>
            {caseStudy.evidence && (
              <div class="space-y-3">
                <p class="section-label">Evidence</p>
                {caseStudy.evidence.map((item) => (
                  <div class="card flex items-start gap-3">
                    <span class="text-[var(--color-accent)] mt-1">▹</span>
                    <p class="text-[var(--color-text-secondary)]">{item}</p>
                  </div>
                ))}
              </div>
            )}
            {caseStudy.metrics && (
              <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                {caseStudy.metrics.map((m) => (
                  <div class="card text-center">
                    <p class="stat-number">{m.value}</p>
                    <p class="stat-label">{m.label}</p>
                  </div>
                ))}
              </div>
            )}
          </div>
        ) : (
          <p class="text-[var(--color-text-secondary)] italic">Detailed case study coming soon.</p>
        )}

        {outboundUrl && (
          <div class="mt-12">
            <a href={outboundUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
              {project.liveUrl ? 'View live system' : 'View on GitHub'}
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M10 5L13 8L10 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </a>
          </div>
        )}
      </div>
    </section>
  </main>
</BaseLayout>
