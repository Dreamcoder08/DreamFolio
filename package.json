{
  "name": "dreamfolio-astro",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": []
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy:pages": "pnpm run build",
    "deploy": "vercel --prod",
    "deploy:staging": "vercel",
    "analyze": "pnpm dlx @next/bundle-analyzer dist/",
    "lighthouse": "pnpm dlx lighthouse http://localhost:4321 --output html --output-path ./lighthouse-report.html",
    "performance": "pnpm run build && pnpm run preview",
    "clean": "rm -rf dist node_modules/.astro"
  },
  "dependencies": {
    "@astrojs/react": "^4.1.0",
    "@hookform/resolvers": "^4.1.3",
"@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^5.18.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.559.0",
    "motion": "^12.39.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.9.0"
  }
}
