{
  "name": "dreamfolio",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": []
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy:pages": "pnpm run build",
    "deploy": "vercel --prod",
    "deploy:staging": "vercel",
    "lighthouse": "pnpm dlx lighthouse http://localhost:4321 --output html --output-path ./lighthouse-report.html",
    "performance": "pnpm run build && pnpm run preview",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('node_modules/.astro',{recursive:true,force:true})\"",
    "check": "astro sync && tsc --noEmit",
    "verify": "pnpm run build && pnpm run check"
  },
  "dependencies": {
    "@astrojs/react": "^4.1.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/vite": "^4.1.17",
    "astro": "^5.18.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.559.0",
    "motion": "^12.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.9.0"
  }
}
